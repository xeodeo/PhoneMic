<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1e1f22"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- ── Toolbar ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="PhoneMic"
                android:textColor="#f2f3f5"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:text="⋮"
                android:textColor="#b5bac1"
                android:textSize="22sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"/>
        </RelativeLayout>

        <!-- ── Mic sphere + status ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- Circle mic indicator -->
            <FrameLayout
                android:id="@+id/micCircle"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_mic_circle">

                <ImageView
                    android:id="@+id/ivMic"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mic"
                    android:tint="#ffffff"/>
            </FrameLayout>

            <!-- Status badge -->
            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="● INACTIVO"
                android:textColor="#ffffff"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <!-- Status message -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Inactivo"
                android:textColor="#80848e"
                android:textSize="13sp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- ── Main card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_card"
            android:padding="16dp">

            <!-- Connection type section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODO DE CONEXIÓN"
                android:textColor="#80848e"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <!-- USB row -->
            <LinearLayout
                android:id="@+id/rowUsb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="🔌"
                    android:textSize="18sp"
                    android:background="#2b2d31"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="USB (ADB)"
                        android:textColor="#f2f3f5"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="localhost : 7777"
                        android:textColor="#80848e"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- WiFi row -->
            <LinearLayout
                android:id="@+id/rowWifi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="📶"
                    android:textSize="18sp"
                    android:background="#2b2d31"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WiFi (red local)"
                        android:textColor="#f2f3f5"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvWifiIp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cargando..."
                        android:textColor="#80848e"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2b2d31"
                android:layout_marginVertical="8dp"/>

            <!-- Volume section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔊  VOLUMEN"
                    android:textColor="#80848e"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvVolume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="#80848e"
                    android:textSize="12sp"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="100"
                android:progressTint="#5865f2"
                android:thumbTint="#5865f2"/>

        </LinearLayout>

        <!-- ── Buttons ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Mute button -->
            <Button
                android:id="@+id/btnMute"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:text="Silenciar micrófono"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_mute"
                android:enabled="false"/>

            <!-- Start/Stop button -->
            <Button
                android:id="@+id/btnToggle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Iniciar"
                android:textColor="#ffffff"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_start"/>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
