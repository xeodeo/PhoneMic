<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1e1f22">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="#1e1f22"
        android:padding="28dp">

        <!-- Header row with 3-dot menu -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerHorizontal="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PhoneMic"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="#f2f3f5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Micrófono por USB ADB"
                    android:textSize="13sp"
                    android:textColor="#80848e"
                    android:layout_marginBottom="0dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="⋮"
                android:textSize="22sp"
                android:textColor="#b5bac1"
                android:gravity="center"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <!-- Spacing -->
        <View android:layout_width="match_parent" android:layout_height="28dp" />

        <!-- Mic circle indicator -->
        <FrameLayout
            android:id="@+id/micCircle"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:background="@drawable/bg_mic_circle"
            android:layout_marginBottom="14dp">

            <ImageView
                android:id="@+id/ivMic"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic"
                android:tint="#ffffff"
                android:contentDescription="Micrófono" />
        </FrameLayout>

        <!-- Connection badge -->
        <TextView
            android:id="@+id/tvBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● INACTIVO"
            android:textSize="11sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:background="@drawable/bg_status_badge"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <!-- Status text -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inactivo"
            android:textSize="13sp"
            android:textColor="#80848e"
            android:gravity="center"
            android:layout_marginBottom="10dp" />

        <!-- Conexión card (USB + WiFi) -->
        <LinearLayout
            android:id="@+id/cardWifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2b2d31"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <!-- Fila USB -->
            <LinearLayout
                android:id="@+id/rowUsb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔌  USB (ADB)"
                    android:textColor="#b5bac1"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="localhost:7777"
                    android:textColor="#5865f2"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Fila WiFi -->
            <LinearLayout
                android:id="@+id/rowWifi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📶  WiFi (red local)"
                    android:textColor="#b5bac1"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvWifiIp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#5865f2"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Start / Stop button -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="200dp"
            android:layout_height="52dp"
            android:text="Iniciar"
            android:textSize="15sp"
            android:textColor="#ffffff"
            android:backgroundTint="#5865f2"
            android:layout_marginBottom="14dp" />

        <!-- Mute button -->
        <Button
            android:id="@+id/btnMute"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="Silenciar micrófono"
            android:textSize="13sp"
            android:textColor="#ffffff"
            android:backgroundTint="#4f545c"
            android:enabled="false"
            android:layout_marginBottom="28dp" />

        <!-- Volume control -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔊 Volumen"
                    android:textColor="#b5bac1"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvVolume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="#b5bac1"
                    android:textSize="13sp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekVolume"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:max="100"
                android:progress="100"
                android:progressTint="#5865f2"
                android:progressBackgroundTint="#3a3d47"
                android:thumb="@drawable/ic_seekbar_thumb"
                android:splitTrack="false"
                android:enabled="false" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
